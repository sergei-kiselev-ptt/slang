expression     ::= assignment ;
assignment     ::= IDENTIFIER "=" assignment
				   | equality;
equality       ::= comparison ( ( "==" | "!=" ) comparison )*;
comparison     ::= term ( ( ">" | ">=" | "<" | "<=" ) term )*;
term           ::= factor ( ( "*" | "/" ) factor )*;
factor         ::= unary;
unary          ::= ( "-" | "+" ) unary | primary;
primary        ::= NUMBER | IDENTIFIER | "true" | "false" | "(" expression ")";
